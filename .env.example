# PostgreSQL (Docker Compose)
DATABASE_URL="postgresql://ecoprompt:ecoprompt_dev@localhost:5432/ecoprompt"

# Redis (Docker Compose)
REDIS_URL="redis://localhost:6379"

# Auth — use uma string aleatória de pelo menos 32 caracteres
JWT_SECRET="troque-por-string-aleatoria-de-pelo-menos-32-chars"
SESSION_TTL_SECONDS=3600

# Chave interna usada pelo middleware para validar sessões Redis
# Deve ser diferente do JWT_SECRET e também aleatória
INTERNAL_API_KEY="outra-string-aleatoria-para-rota-interna"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
